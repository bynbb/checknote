{
  "name": "checknote",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bazelisk build //api:checknote_site_zip",
    "test:api": "bazelisk build //api/src/App:api_route_smoke_check",
    "check:architecture": "node tools/check-boundaries.mjs --src-dir cdev/src",
    "test:architecture": "node tools/check-boundaries.test.mjs",
    "serve": "cd cdev && ..\\node_modules\\.bin\\ng.cmd serve --host 127.0.0.1 --port 4200",
    "ng": "cd cdev && ..\\node_modules\\.bin\\ng.cmd"
  },
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/platform-browser": "21.2.11",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.11",
    "@bazel/bazelisk": "1.28.1",
    "typescript": "~5.9.0"
  }
}
