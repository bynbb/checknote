{
  "name": "checknote",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bazelisk build //api:checknote_site_zip //deployment/database:checknote_db_tool_zip",
    "ci:build-and-test": "bazelisk build //api:checknote_site_zip //deployment/database:checknote_db_tool_zip //api/test/unit:unit_tests //api/src/App:api_route_smoke_check //cdev/test/unit:unit_tests //cdev/test/architecture:architecture_tests //tools/test:unit_tests",
    "db:apply": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/apply-database.ps1",
    "test": "npm run test:backend && npm run test:frontend && npm run test:tools",
    "test:backend": "npm run test:api",
    "test:api": "bazelisk build //api/test/unit:unit_tests && bazelisk build //api/src/App:api_route_smoke_check",
    "test:frontend": "bazelisk build //cdev/test/unit:unit_tests && bazelisk build //cdev/test/architecture:architecture_tests",
    "test:tools": "bazelisk build //tools/test:unit_tests",
    "check:architecture": "node tools/check-boundaries.mjs --src-dir cdev/src",
    "test:architecture": "npm run test:frontend && npm run test:tools",
    "serve": "cd cdev && ..\\node_modules\\.bin\\ng.cmd serve --host 127.0.0.1 --port 4200",
    "ng": "cd cdev && ..\\node_modules\\.bin\\ng.cmd"
  },
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/cdk": "21.2.10",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/material": "21.2.10",
    "@angular/platform-browser": "21.2.11",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.11",
    "@bazel/bazelisk": "1.28.1",
    "typescript": "~5.9.0"
  }
}
