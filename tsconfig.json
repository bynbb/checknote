{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "paths": {
      "@cdev/app/*": ["cdev/src/app/*"],
      "@cdev/common/application": ["cdev/src/common/application/index.ts"],
      "@cdev/common/application/*": ["cdev/src/common/application/*"],
      "@cdev/common/composition": ["cdev/src/common/composition/index.ts"],
      "@cdev/common/composition/*": ["cdev/src/common/composition/*"],
      "@cdev/common/domain": ["cdev/src/common/domain/index.ts"],
      "@cdev/common/domain/*": ["cdev/src/common/domain/*"],
      "@cdev/common/infrastructure": ["cdev/src/common/infrastructure/index.ts"],
      "@cdev/common/infrastructure/*": ["cdev/src/common/infrastructure/*"],
      "@cdev/common/presentation": ["cdev/src/common/presentation/index.ts"],
      "@cdev/common/presentation/*": ["cdev/src/common/presentation/*"],
      "@cdev/modules/todos/application": ["cdev/src/modules/todos/application/index.ts"],
      "@cdev/modules/todos/application/*": ["cdev/src/modules/todos/application/*"],
      "@cdev/modules/todos/composition": ["cdev/src/modules/todos/composition/index.ts"],
      "@cdev/modules/todos/composition/*": ["cdev/src/modules/todos/composition/*"],
      "@cdev/modules/todos/domain": ["cdev/src/modules/todos/domain/index.ts"],
      "@cdev/modules/todos/domain/*": ["cdev/src/modules/todos/domain/*"],
      "@cdev/modules/todos/infrastructure": ["cdev/src/modules/todos/infrastructure/index.ts"],
      "@cdev/modules/todos/infrastructure/*": ["cdev/src/modules/todos/infrastructure/*"],
      "@cdev/modules/todos/presentation": ["cdev/src/modules/todos/presentation/index.ts"],
      "@cdev/modules/todos/presentation/*": ["cdev/src/modules/todos/presentation/*"],
      "@cdev/modules/users/application": ["cdev/src/modules/users/application/index.ts"],
      "@cdev/modules/users/application/*": ["cdev/src/modules/users/application/*"],
      "@cdev/modules/users/composition": ["cdev/src/modules/users/composition/index.ts"],
      "@cdev/modules/users/composition/*": ["cdev/src/modules/users/composition/*"],
      "@cdev/modules/users/domain": ["cdev/src/modules/users/domain/index.ts"],
      "@cdev/modules/users/domain/*": ["cdev/src/modules/users/domain/*"],
      "@cdev/modules/users/infrastructure": ["cdev/src/modules/users/infrastructure/index.ts"],
      "@cdev/modules/users/infrastructure/*": ["cdev/src/modules/users/infrastructure/*"],
      "@cdev/modules/users/presentation": ["cdev/src/modules/users/presentation/index.ts"],
      "@cdev/modules/users/presentation/*": ["cdev/src/modules/users/presentation/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
